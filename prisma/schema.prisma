generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CASHIER
  KITCHEN
}

enum OrderStatus {
  DRAFT
  SENT
  PREPARING
  READY
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  DIGITAL
  UPI
}

enum SelfOrderMode {
  ONLINE_ORDERING
  QR_MENU
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  username  String?  @unique
  password  String
  role      UserRole @default(CASHIER)
  otp       String?
  otpExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  orders   Order[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  color     String    @default("#3b82f6")
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  categoryId  String
  price       Float
  tax         Float    @default(0)
  uom         String?  @default("Unit")
  priceTaxIncluded Boolean @default(true)
  description String?
  imageUrl    String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  variants   ProductVariant[]
  orderItems OrderItem[]
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  attribute  String
  value      String
  extraPrice Float   @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model Floor {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tables Table[]
}

model Table {
  id        String   @id @default(cuid())
  floorId   String
  number    String
  seats     Int      @default(4)
  isActive  Boolean  @default(true)
  tableType String?  @default("Table")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  floor    Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  orders   Order[]
  qrTokens QRToken[]
}

model POSConfig {
  id            String        @id @default(cuid())
  cashEnabled   Boolean       @default(true)
  digitalEnabled Boolean      @default(true)
  upiEnabled    Boolean       @default(false)
  upiId         String?
  selfOrderEnabled Boolean    @default(false)
  selfOrderMode  SelfOrderMode @default(ONLINE_ORDERING)
  bgImageUrl    String?
  updatedAt     DateTime      @updatedAt
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  openingCash  Float     @default(0)
  closingCash  Float?

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]
}

model Order {
  id        String      @id @default(cuid())
  tableId   String?
  sessionId String?
  userId    String?
  status    OrderStatus @default(DRAFT)
  total     Float       @default(0)
  note      String?
  isQrOrder Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  table   Table?      @relation(fields: [tableId], references: [id])
  session Session?    @relation(fields: [sessionId], references: [id])
  user    User?       @relation(fields: [userId], references: [id])
  items   OrderItem[]
  payment Payment?
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  variantId   String?
  quantity    Int     @default(1)
  price       Float
  isPrepared  Boolean @default(false)
  note        String?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model Payment {
  id      String        @id @default(cuid())
  orderId String        @unique
  method  PaymentMethod
  amount  Float
  paidAt  DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model QRToken {
  id        String   @id @default(cuid())
  tableId   String
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())

  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)
}
